<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">

    <!-- 全局只有一个Servlet which handles all requests
    from client：DispatcherServlet  -->
    <servlet>
        <servlet-name>dispatcher</servlet-name>
        <servlet-class>org.springframework.web.servlet.DispatcherServlet</servlet-class>
        <!-- dispatcherServlet will create a Spring IOC container by
        loading the configuration from the specified location 'classpath:spring-mvc.xml'.
        load-on-startup: This element specifies the order in which the servlet should be loaded when the application starts.
        A value of 1 means that this servlet should be loaded before any other servlets with
        a higher value (or no value, which defaults to 0).
        Since dispatcherServlet creates the Spring IOC container,
        we want it to be loaded as early as possible.
        -->
        <init-param>
            <param-name>contextConfigLocation</param-name>
            <param-value>classpath:spring-mvc.xml</param-value>
        </init-param>
        <load-on-startup>1</load-on-startup>
    </servlet>

    <servlet-mapping>
        <servlet-name>dispatcher</servlet-name>
        <!-- Map all requests to the DispatcherServlet.
        This means that the DispatcherServlet
        will handle all incoming requests to the application. -->
        <url-pattern>/</url-pattern>
    </servlet-mapping>
</web-app>