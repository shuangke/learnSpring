<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xmlns:context="http://www.springframework.org/schema/context"
       xmlns:mvc="http://www.springframework.org/schema/mvc"
       xsi:schemaLocation="http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans.xsd
                           http://www.springframework.org/schema/context http://www.springframework.org/schema/context/spring-context.xsd
                           http://www.springframework.org/schema/mvc http://www.springframework.org/schema/mvc/spring-mvc.xsd">

    <!-- Enable automatic component scanning for controllers and services -->
    <context:component-scan base-package="controllers"/>

    <!--
    DispatcherServlet会根据请求URL，问询HandlerMapping找到对应的处理器（Controller）和方法，然后交给HandlerAdapter来执行处理器的方法。
    HandlerMapping：它相当于一个秘书有一个地址簿，里面记录了每个URL对应哪个Controller和方法。
    HandlerAdapter：执行处理器（Controller）的方法，并返回ModelAndView对象。
    1. step1：DispatcherServlet接收到请求后，首先会调用HandlerMapping来查找处理器（Controller）和方法。
    2. step2：HandlerMapping会根据请求URL和配置的映射规则，找到对应的处理器（Controller）和方法，并返回一个HandlerExecutionChain对象。
    3. step3：DispatcherServlet接收到HandlerExecutionChain对象后，会调用HandlerAdapter来执行处理器（Controller）的方法。
    4. step4：HandlerAdapter会根据HandlerExecutionChain对象中的处理器（Controller）和方法，解析请求参数，并调用处理器（Controller）的方法来处理请求。
    5. step5：处理器（Controller）的方法执行完成后，HandlerAdapter 会返回json数据或者ModelAndView对象给DispatcherServlet，DispatcherServlet会根据返回的结果来渲染视图或者返回json数据。
    spring-mvc.xml中如果没有manually配置RequestMappingHandlerMapping和RequestMappingHandlerAdapter，会有default的HandlerMapping和HandlerAdapter来处理请求，
    但是我们可以手动配置RequestMappingHandlerMapping和RequestMappingHandlerAdapter来覆盖默认的配置，
    以便更好地控制请求的处理过程。
    -->
    <bean class="org.springframework.web.servlet.mvc.method.annotation.RequestMappingHandlerMapping" />
    <bean class="org.springframework.web.servlet.mvc.method.annotation.RequestMappingHandlerAdapter" />
</beans>